{
    "doctype": "DocType",
    "istable": 1,
    "custom": 1,
    "module": "RERA Escalation",
    "name": "RERA Response Log",
    "fields": [
        {
            "fieldname": "log_date",
            "fieldtype": "Date",
            "reqd": 1
        },
        {
            "fieldname": "activity_type",
            "fieldtype": "Select",
            "options": "Response Filed\\nHearing Attended\\nDocument Submitted\\nNotice Received\\nSettlement Discussion\\nOrder Received",
            "reqd": 1
        },
        {
            "fieldname": "description",
            "fieldtype": "Text",
            "reqd": 1
        },
        {
            "fieldname": "filed_by",
            "fieldtype": "Link",
            "options": "User"
        },
        {
            "fieldname": "document",
            "fieldtype": "Attach"
        },
        {
            "fieldname": "next_action",
            "fieldtype": "Small Text"
        },
        {
            "fieldname": "next_action_date",
            "fieldtype": "Date"
        }
    ]
}