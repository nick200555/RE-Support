{
    "doctype": "DocType",
    "module": "Buyer Portal",
    "name": "Portal Notification",
    "autoname": "PNOT-.YYYY.MM.DD.-.##",
    "fields": [
        {
            "fieldname": "buyer",
            "fieldtype": "Link",
            "options": "Contact",
            "reqd": 1
        },
        {
            "fieldname": "notification_type",
            "fieldtype": "Select",
            "options": "Ticket Created\\nStatus Changed\\nSLA Breach\\nPossession Update\\nDefect Update\\nRERA Notice"
        },
        {
            "fieldname": "channel",
            "fieldtype": "Select",
            "options": "WhatsApp\\nEmail\\nSMS\\nIn-App"
        },
        {
            "fieldname": "reference_doctype",
            "fieldtype": "Link",
            "options": "DocType"
        },
        {
            "fieldname": "source_document",
            "fieldtype": "Dynamic Link",
            "options": "reference_doctype"
        },
        {
            "fieldname": "message",
            "fieldtype": "Text"
        },
        {
            "fieldname": "sent_at",
            "fieldtype": "Datetime"
        },
        {
            "fieldname": "delivery_status",
            "fieldtype": "Select",
            "options": "Sent\\nDelivered\\nRead\\nFailed"
        },
        {
            "fieldname": "failure_reason",
            "fieldtype": "Small Text"
        }
    ],
    "permissions": [
        {
            "create": 1,
            "delete": 1,
            "email": 1,
            "export": 1,
            "print": 1,
            "read": 1,
            "report": 1,
            "role": "System Manager",
            "share": 1,
            "write": 1
        }
    ]
}